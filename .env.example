# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=more3zdenai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strongpassword123

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=60

# ── RAG / FAISS ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=/app/data/faiss.index
FAISS_CHUNKS_PATH=/app/data/chunks.pkl
KNOWLEDGE_BASE_DIR=/app/knowledge_base
RAG_TOP_K=5
RAG_MIN_SCORE=0.3
RAG_CACHE_TTL=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Text-to-Speech (LuxTTS voice cloning) ──────────────────────────────────────
# Drop the voice to clone at tts/voices/reference.wav and set REFERENCE_TEXT to
# the exact words spoken in that clip. Set LUXTTS_DEVICE=cuda for GPU.
TTS_ENABLED=True
TTS_BASE_URL=http://tts:9000
TTS_TIMEOUT=120
LUXTTS_MODEL_ID=YatharthS/LuxTTS
LUXTTS_DEVICE=cpu
REFERENCE_TEXT=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost
